account={"นางA":10000,"นางB":0}

def getBalance():
    print("ยอดเงินคงเหลือในบัญชี :",account)

def deposit(money):
    if not type(money) is int and not type(money) is float:
        raise Exception("ต้องป้อนตัวเลขเท่านั้น")
    if money<=0:
        raise Exception ("ค่าตัวเลขต้องเป็นบวกเท่านั้น")
    print("ฝากเงินเข้าบัญชี A :",money)
    account["นางA"]+=money

def withdraw(money):
    if not type(money) is int:
        raise Exception("ต้องป้อนตัวเลขเท่านั้น")
    if money<=0:
        raise Exception ("ค่าตัวเลขต้องเป็นบวกเท่านั้น")
    if money>account["นางA"]:
        raise Exception ("ยอดเงินในบัญชีไม่พอ")

    print("ถอนเงินจากบัญชี A:",money)
    account["นางA"]-=money

def transfer(money):
    if not type(money) is int and not type(money) is float:
        raise Exception("ต้องป้อนตัวเลขเท่านั้น")
    if money<=0:
        raise Exception ("ค่าตัวเลขต้องเป็นบวกเท่านั้น")
    if money>account["นางA"]:
        raise Exception ("ยอดเงินในบัญชีไม่พอ")
    print("ทำการโอนเงินไปที่บัญชี B :",money)
    account["นางB"]+=money
    account["นางA"]-=money
try:
    getBalance()
    transfer(500.12)
    getBalance()
except Exception as e:
    print(e)
